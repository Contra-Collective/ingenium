{
  "name": "riftexpress-redis",
  "version": "0.0.1",
  "description": "Redis-backed session, idempotency, and rate-limit stores for RiftExpress. Drop-in replacements for the in-memory defaults; required for multi-instance deployments.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": ["src"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "redis",
    "session",
    "idempotency",
    "rate-limit",
    "riftexpress",
    "multi-instance"
  ],
  "license": "MIT",
  "peerDependencies": {
    "riftexpress": "*"
  },
  "peerDependenciesMeta": {
    "riftexpress": { "optional": false }
  },
  "devDependencies": {
    "vitest": "^2.0.0"
  }
}
