{
  "name": "riftexpress-cli",
  "version": "0.0.1",
  "description": "Project scaffolder CLI for RiftExpress.",
  "type": "module",
  "bin": {
    "riftex": "./bin/riftex.mjs"
  },
  "main": "./src/cli.ts",
